# ===== Plantilla de variables de entorno =====
# Copia este archivo como ".env" (sin .example) y rellena los valores reales.
# El archivo .env NUNCA se sube a git (está en .gitignore).

# Cadena de conexión a MongoDB Atlas.
# Pégala en tu archivo .env, NO aquí. Recuerda poner la base "alerta_ciudadana".
# Ejemplo de formato (no son credenciales reales):
MONGODB_URI="mongodb+srv://USUARIO:CONTRASENA@cluster0.xxxxx.mongodb.net/alerta_ciudadana?retryWrites=true&w=majority"

# Puerto en el que corre el servidor backend.
PORT=4000

# Secreto para firmar los tokens de sesión (JWT). Usa una frase larga y aleatoria.
JWT_SECRET=cambia_esto_por_una_frase_larga_y_secreta
